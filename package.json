{
  "name": "cus-multi-table",
  "type": "module",
  "version": "1.0.1",
  "description": "Multidimensional data render to table. A Vue 3 component with TypeScript built with Vite",
  "main": "dist/cus-multi-table.umd.js",
  "module": "dist/cus-multi-table.es.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "vue",
    "component",
    "typescript",
    "Multidimensional data",
    "table"
  ],
  "author": "amsuperking <amsuperking@qq.com>",
  "repository": {
    "type": "github",
    "url": "git+https://github.com/AmSuperKing/cus-multi-table.git#main"
  },
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.69.0",
    "prettier": "3.8.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}